<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cinestar2.Pages.DetaljiFilma"
             BackgroundColor="#051851">

    <Grid RowDefinitions="*,Auto">

        <Grid BackgroundColor="#051851" HeightRequest="60" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="logoo.png"
                   HeightRequest="70"
                   WidthRequest="150"
                   VerticalOptions="Center"
                   Margin="1,20,1,0"
                   Grid.Column="0"/>

            <Picker Title="Izaberi grad"
                    TitleColor="White"
                    TextColor="White"
                    Grid.Column="2"
                    VerticalOptions="Center"
                    Margin="0,20,20,0">
                <Picker.Items>
                    <x:String>Zenica</x:String>
                    <x:String>Sarajevo</x:String>
                    <x:String>Mostar</x:String>
                    <x:String>Tuzla</x:String>
                    <x:String>Banja Luka</x:String>
                </Picker.Items>
            </Picker>
        </Grid>

        <ScrollView Grid.Row="1" BackgroundColor="#051851">
            <VerticalStackLayout Spacing="20" Padding="15">

                <Label x:Name="NaslovLabel"
                       TextColor="White"
                       FontSize="24"
                       FontAttributes="Bold"/>

                <Grid HeightRequest="250">
                    <Image x:Name="PosterImage" Aspect="AspectFill"/>
                    <BoxView BackgroundColor="#80000000" VerticalOptions="End" HeightRequest="50"/>
                    <VerticalStackLayout VerticalOptions="End" Padding="10">
                        <Label x:Name="TrajanjeLabel" TextColor="White" FontSize="16"/>
                        <Label x:Name="OcjenaLabel" TextColor="White" FontSize="16"/>
                    </VerticalStackLayout>
                </Grid>

                <Label x:Name="OpisLabel" TextColor="White" FontSize="16" LineBreakMode="WordWrap"/>

                <FlexLayout HeightRequest="90" AlignItems="Center" Direction="Row" Wrap="Wrap">
                    <Frame Margin="0,0,3,0" Padding="20,10" BackgroundColor="#6532fd" CornerRadius="200">
                        <Label FontSize="10" TextColor="White" Text="ACTION"/>
                    </Frame>
                    <Frame Margin="0,0,3,0" Padding="20,10" BackgroundColor="#6532fd" CornerRadius="200">
                        <Label FontSize="10" TextColor="White" Text="ADVENTURE"/>
                    </Frame>
                    <Frame Margin="0,0,3,0" Padding="20,10" BackgroundColor="#6532fd" CornerRadius="200">
                        <Label FontSize="10" TextColor="White" Text="HORROR"/>
                    </Frame>
                </FlexLayout>

                <Button Text="Kupi Karte"
                        BackgroundColor="#FF4500"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Clicked="KupiKarte_Clicked"/>

                <Frame BorderColor="Transparent" Margin="0,0,0,10" CornerRadius="0" BackgroundColor="#EEEEEE">
                    <FlexLayout Direction="Row" JustifyContent="SpaceAround">
                        <VerticalStackLayout Spacing="4">
                            <Frame HeightRequest="50" WidthRequest="50" CornerRadius="100" BackgroundColor="#6532fd">
                                <Image HeightRequest="20" WidthRequest="20" Source="plus.png"/>
                            </Frame>
                            <Label HorizontalOptions="Center" Text="My List"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="4">
                            <Frame HeightRequest="50" WidthRequest="50" CornerRadius="100" BackgroundColor="#6532fd">
                                <Image HeightRequest="20" WidthRequest="20" Source="send.png"/>
                            </Frame>
                            <Label HorizontalOptions="Center" Text="Share"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="4">
                            <Frame HeightRequest="50" WidthRequest="50" CornerRadius="100" BackgroundColor="#6532fd">
                                <Image HeightRequest="20" WidthRequest="20" Source="bookmark.png"/>
                            </Frame>
                            <Label HorizontalOptions="Center" Text="Save"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="4">
                            <Frame HeightRequest="50" WidthRequest="50" CornerRadius="100" BackgroundColor="#6532fd">
                                <Image HeightRequest="20" WidthRequest="20" Source="favourites.png"/>
                            </Frame>
                            <Label HorizontalOptions="Center" Text="Favourites"/>
                        </VerticalStackLayout>
                    </FlexLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
