<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cinestar2.MainPage"
             BackgroundColor="#051851"
             NavigationPage.HasBackButton="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" BackgroundColor="#051851">
            <VerticalStackLayout Spacing="20">

                <Grid BackgroundColor="#051851" HeightRequest="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="logoo.png"
                           HeightRequest="70"
                           WidthRequest="150"
                           VerticalOptions="Center"
                           Margin="1,20,1,0"
                           Grid.Column="0"/>

                    <Picker Title="Izaberi grad"
                            ItemsSource="{Binding Gradovi}"
                            SelectedItem="{Binding IzabraniGrad}"
                            TitleColor="White"
                            TextColor="White"
                            FontSize="10"
                            Grid.Column="2"
                            VerticalOptions="Center"
                            Margin="0,20,20,0">
                    
                    </Picker>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="Gray" HorizontalOptions="Fill" Margin="0,5"/>

                <Label Text="TRAILERI" TextColor="White" FontSize="20" Margin="15,10" />

                
                    <CollectionView ItemsSource="{Binding Traileri}"
                     ItemsLayout="HorizontalList"
                     HeightRequest="170"
                     Margin="15">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                            <Grid WidthRequest="280" HeightRequest="170" Margin="0,0,10,0" >
                                    <Image Source="{Binding Slika}" Aspect="AspectFill"/>
                                    <BoxView BackgroundColor="#80000000" VerticalOptions="End" HeightRequest="50"/>
                                    <VerticalStackLayout VerticalOptions="End" Padding="10">
                                        <Label Text="{Binding Naziv}" TextColor="White" FontAttributes="Bold" FontSize="10"/>
                                        <Label Text="{Binding Trajanje, StringFormat='{}{0} min'}" TextColor="White" FontSize="10"/>
                                        
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

               

                <BoxView HeightRequest="1" BackgroundColor="Gray" HorizontalOptions="Fill" Margin="0,5"/>
                <Label Text="EXTREME REALD 3D" Margin="5" Padding="5" HorizontalOptions="Center" TextColor="White" FontFamily="MojFont"/>
                <BoxView HeightRequest="1" BackgroundColor="Gray" HorizontalOptions="Fill" Margin="0,5"/>
                <Label Text="NA PROGRAMU" TextColor="White" Margin="10" Padding="5" FontSize="17"/>

                <CollectionView ItemsSource="{Binding FilmoviNaProgramu}"
                                ItemsLayout="VerticalGrid, 2"
                                Margin="15">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="5" CornerRadius="10" Margin="5" HasShadow="False" BackgroundColor="Transparent">
                                <StackLayout>
                                    <Image Source="{Binding Slika}" HeightRequest="250" Aspect="AspectFill"/>
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
