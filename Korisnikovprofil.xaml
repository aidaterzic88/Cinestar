<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="Cinestar2.Korisnikovprofil"
             BackgroundColor="#051851"
             NavigationPage.HasBackButton="True">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="40">

            <VerticalStackLayout Spacing="10">
                <Label Text="Moj Profil"
                       FontSize="26"
                       TextColor="White"
                       FontAttributes="Bold"/>

                <BoxView HeightRequest="3">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFD600" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
            </VerticalStackLayout>

            <Grid Margin="0,10,0,0">

              
                <Frame BackgroundColor="#FFD600"
           CornerRadius="10"
           HeightRequest="250"
           Margin="10,0,0,0"
           TranslationY="-25"
           Rotation="-2"/>

                <Frame BackgroundColor="#0A2A7A"
           CornerRadius="15"
           Padding="15"
           HasShadow="True">

                    <VerticalStackLayout Spacing="15">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Moje informacije"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"
                       Grid.Column="0"/>
                            <Button Text="Odjavi se"
                        Command="{Binding OdjavaCommand}"
                        BackgroundColor="#FFD600"
                        TextColor="Black"
                        CornerRadius="10"
                        FontSize="12"
                        Padding="10,5"
                        HorizontalOptions="End"
                        Grid.Column="1"/>
                        </Grid>

                        <Label Text="{Binding Korisnik.Email}"
                   TextColor="#DDDDDD"
                   FontSize="14"/>

                        <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="20">

                            <VerticalStackLayout Spacing="8" Grid.Column="0">
                                <Label Text="{Binding Korisnik.Spol, StringFormat='Spol: {0}'}"
                           TextColor="White"/>
                                <Label Text="{Binding Korisnik.ImePrezime, StringFormat='Ime i prezime: {0}'}"
                           TextColor="White"/>
                                <Label Text="{Binding Korisnik.DatumRodjenja, StringFormat='Datum rođenja: {0}'}"
                           TextColor="White"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8" Grid.Column="1">
                                <Label Text="{Binding Korisnik.Adresa, StringFormat='Adresa: {0}'}"
                           TextColor="White"/>
                                <Label Text="{Binding Korisnik.Grad, StringFormat='Grad: {0}'}"
                           TextColor="White"/>
                                <Label Text="{Binding Korisnik.Drzava, StringFormat='Država: {0}'}"
                           TextColor="White"/>
                            </VerticalStackLayout>

                        </Grid>
                    </VerticalStackLayout>
                </Frame>
            </Grid>


           
            <Grid Margin="0,10,0,0">

                <Frame BackgroundColor="#FFD600"
                       CornerRadius="15"
                       HeightRequest="160"
                       Margin="10,0,0,0"
                       TranslationY="-20"
                       Rotation="-1.5"/>

             
                <Frame BackgroundColor="#0A2A7A"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="10">

                     
                        <Label Text="O nama"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Label Text="Cinestar je vodeći kino lanac koji pruža vrhunsko filmsko iskustvo uz najnoviju tehnologiju projekcije i udobnost."
                               TextColor="#DDDDDD"
                               FontSize="14"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Grid Margin="0,10,0,0">

                <Frame BackgroundColor="#FFD600"
                       CornerRadius="15"
                       HeightRequest="140"
                       Margin="10,0,0,0"
                       TranslationY="-15"
                       Rotation="-1"/>

                <Frame BackgroundColor="#0A2A7A"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="8">

                        <Label Text="Kontakt"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Label Text="📞 +387 33 123 456"
                               TextColor="White"/>

                        <Label Text="✉ info@cinestar.ba"
                               TextColor="White"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Grid Margin="0,10,0,0">

                <Frame BackgroundColor="#FFD600"
                       CornerRadius="15"
                       HeightRequest="220"
                       Margin="10,0,0,0"
                       TranslationY="-20"
                       Rotation="-2"/>

                <Frame BackgroundColor="#0A2A7A"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Lokacija"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"
                               Margin="0,10,0,5"/>

                        <Frame BackgroundColor="#1E1E1E" CornerRadius="10" HeightRequest="150">
                            <Label Text="Google Maps – kino za izabrani grad" 
                                   TextColor="Gray" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                    </VerticalStackLayout>
                </Frame>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
