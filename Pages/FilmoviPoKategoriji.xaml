<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cinestar2.FilmoviPoKategoriji"
             BackgroundColor="#051851">

	<VerticalStackLayout Padding="15" Spacing="20">

		
		<Label x:Name="NaslovKategorije"
               TextColor="White"
               FontSize="22"
               FontAttributes="Bold"
               Margin="0,10"/>

	
		<CollectionView x:Name="ListaFilmova"
                        BackgroundColor="Transparent"
                        SelectionMode="None"
                        ItemsLayout="VerticalList">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Frame CornerRadius="10"
                           Padding="10"
                           Margin="0,5"
                           BackgroundColor="#2A3B6E">
						<HorizontalStackLayout Spacing="15">
							<Image Source="{Binding Slika}" WidthRequest="60" HeightRequest="90"/>
							<VerticalStackLayout>
								<Label Text="{Binding Naziv}" TextColor="White" FontSize="18" FontAttributes="Bold"/>
								<Label Text="{Binding Godina}" TextColor="LightGray" FontSize="14"/>
							</VerticalStackLayout>
						</HorizontalStackLayout>
					</Frame>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</VerticalStackLayout>
</ContentPage>
